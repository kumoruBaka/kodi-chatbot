# Gemini API Keys (Use semicolon to rotate multiple keys)
GEMINI_API_KEY=your_api_key1;your_api_key2

# Server Port
PORT=3000

# Developer Mode (Set to "yes" for unlimited chats)
DEV_MODE=yes

# CORS Allowed Origin (Use * to allow all, or specify a domain)
# Examples: https://yourdomain.com | http://localhost:3000 | *
CORS_ORIGIN=*

